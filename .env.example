# ==============================
# NeuralPump Configuration
# ==============================

# OpenAI API Key (required for AI analysis)
OPENAI_API_KEY=sk-...

# Solana RPC URL (use a fast RPC for low latency)
# Free options: https://api.mainnet-beta.solana.com
# Paid (recommended): Helius, QuickNode, Alchemy
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Wallet private key as base58 string (NEVER share this!)
# Only needed for auto-trading mode
WALLET_PRIVATE_KEY=

# ==============================
# Trading Configuration
# ==============================

# Amount of SOL to spend per trade (default: 0.1)
BUY_AMOUNT_SOL=0.1

# Minimum AI score (0-100) required to trigger a buy (default: 75)
MIN_SCORE_TO_BUY=75

# Take profit percentage (default: 100 = 2x)
TAKE_PROFIT_PCT=100

# Stop loss percentage (default: 30 = -30%)
STOP_LOSS_PCT=30

# Maximum concurrent open positions (default: 5)
MAX_POSITIONS=5

# ==============================
# AI Configuration
# ==============================

# OpenAI model to use (gpt-4o-mini is fast and cheap)
GPT_MODEL=gpt-4o-mini

# Maximum tokens for AI response
GPT_MAX_TOKENS=500

# ==============================
# PumpFun Configuration
# ==============================

# PumpFun WebSocket URL (do not change)
PUMP_WS_URL=wss://pumpportal.fun/api/data

# ==============================
# Logging
# ==============================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Save logs to file (true/false)
LOG_TO_FILE=true
